{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Episko",
  "version": "0.10.1",
  "identifier": "io.respeak.episko",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Episko",
        "width": 1200,
        "height": 800,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY1QzE4MTkxMEIyOTUzRDgKUldUWVV5a0xrWUhCOWRBTG5nMlhjdEE5V0xJc0xCRUFGQnlnRFEvVUNZMU5jSWdtVW5XUnl6V08K",
      "endpoints": [
        "https://github.com/respeak-io/episko/releases/latest/download/latest.json"
      ]
    }
  }
}
